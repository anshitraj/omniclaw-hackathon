# ============================================================
# OmniClaw Console - Environment Configuration
# ============================================================
# Copy this file to .env.local and fill in credentials.
# The app expects OmniClaw live execution.
# ============================================================

# ============================================================
# OmniClaw Integration
# ============================================================
# OMNICLAW_API_URL=https://your-omniclaw-backend.example.com
# OMNICLAW_API_TOKEN=your_token_here
# CIRCLE_GATEWAY_API_KEY=your_circle_gateway_testnet_api_key
# Optional (defaults to testnet)
# CIRCLE_GATEWAY_BASE_URL=https://gateway-api-testnet.circle.com
# Optional retry tuning for transient 425 wallet-initializing pay errors:
# OMNICLAW_PAY_RETRY_MAX_ATTEMPTS=4
# OMNICLAW_PAY_RETRY_DELAYS_MS=1200,2200,3500

# ============================================================
# AI Provider (optional)
# ============================================================
# FEATHERLESS_API_KEY=
# FEATHERLESS_API_URL=https://api.featherless.ai/v1/chat/completions

# ============================================================
# App Config
# ============================================================
NEXT_PUBLIC_APP_ENV=live
