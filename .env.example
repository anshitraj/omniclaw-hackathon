# ============================================================
# OmniClaw Console - Environment Configuration
# ============================================================
# Copy this file to .env.local and fill in credentials.
# The app works in DEMO MODE if no credentials are set.
#
# IMPORTANT:
# - Legacy single-wallet variables remain supported for local/demo fallback.
# - Real live commerce requires DISTINCT buyer and seller wallets.
# ============================================================

# ============================================================
# OmniClaw Integration (optional)
# ============================================================
# Server mode (optional)
# OMNICLAW_API_URL=https://your-omniclaw-backend.example.com
# OMNICLAW_API_TOKEN=your_token_here

# ============================================================
# Circle W3S - Buyer Wallet (recommended)
# ============================================================
# CIRCLE_BUYER_API_KEY=
# CIRCLE_BUYER_ENTITY_SECRET=
# CIRCLE_BUYER_WALLET_SET_ID=
# CIRCLE_BUYER_WALLET_ID=
# CIRCLE_BUYER_WALLET_ADDRESS=
# CIRCLE_BUYER_WALLET_BLOCKCHAIN=ARC-TESTNET

# ============================================================
# Circle W3S - Seller Wallet (recommended)
# ============================================================
# CIRCLE_SELLER_API_KEY=
# CIRCLE_SELLER_ENTITY_SECRET=
# CIRCLE_SELLER_WALLET_SET_ID=
# CIRCLE_SELLER_WALLET_ID=
# CIRCLE_SELLER_WALLET_ADDRESS=
# CIRCLE_SELLER_WALLET_BLOCKCHAIN=ARC-TESTNET

# ============================================================
# Legacy Single-Wallet Compatibility (demo/transition only)
# ============================================================
# CIRCLE_API_KEY=
# CIRCLE_ENTITY_SECRET=
# CIRCLE_WALLET_SET_ID=
# CIRCLE_WALLET_ID=
# CIRCLE_WALLET_ADDRESS=
# CIRCLE_WALLET_BLOCKCHAIN=ARC-TESTNET

# ============================================================
# Arc
# ============================================================
# ARC_RPC_URL=
# ARC_EXPLORER_URL=https://testnet.arcscan.app

# ============================================================
# Payment Rail Controls (optional)
# ============================================================
# CIRCLE_GATEWAY_ENABLED=true
# OMNICLAW_FORCE_DIRECT_RAIL=false

# ============================================================
# AI Providers (optional)
# ============================================================
# GEMINI_API_KEY=
# FEATHERLESS_API_KEY=
# FEATHERLESS_API_URL=https://api.featherless.ai/v1/chat/completions
# AIMLAPI_API_KEY=
# AIMLAPI_URL=https://api.aimlapi.com/v1/chat/completions

# ============================================================
# App Config
# ============================================================
NEXT_PUBLIC_APP_ENV=demo
